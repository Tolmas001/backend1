        "socket.io-client": "^4.8.3",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cheerio": "^0.22.35",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^2.1.0",
        "@types/node": "^20.11.5",
        "@types/socket.io": "^3.0.2",
