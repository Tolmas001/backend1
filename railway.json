{
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "pnpm install && pnpm build && npx prisma db push",
        "startCommand": "node dist/index.js"
    },
    "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}